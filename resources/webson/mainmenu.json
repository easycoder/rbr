{
    "#doc": "The main menu, accessed from the title bar hamburger",
    "#element": "div",
    "width": "100%",
    "text-align": "center",
    "padding": "1em 0",
    "background": "#ffc",
    "#": ["$GetName", "$GetRequest", "$Pad", "$Add", "$Pad", "$Cancel"],

    "$GetName": {
        "$ID": "button-getname",
        "$Label": "Set the system name",
        "#": "$Button"
    },

    "$GetRequest": {
        "$ID": "button-getrequest",
        "$Label": "Name the request relay",
        "#": "$Button"
    },

    "$Add": {
        "$ID": "button-add",
        "$Label": "Add a room",
        "#": "$Button"
    },

    "$Cancel": {
        "$ID": "button-cancel",
        "$Label": "Cancel",
        "#": "$Button"
    },

    "$Pad": {
        "#element": "div",
        "height": "1em"
    },

    "$Button": {
        "#element": "button",
        "@id": "$ID",
        "display": "block",
        "width": "60%",
        "font-size": "1.2em",
        "margin": "0 auto 0.5em auto",
        "border-radius": "0.25em",
        "#content": "$Label"
    }
}