{
    "#doc": "EditProfileRow template — rendered once per editable profile in the editor sheet. /I/ replaced with index. shell.as fills the name and wires Rename / Delete clicks.",
    "#element": "div",
    "@id": "edit-profile-row-/I/",
    "padding": "12px 14px",
    "border-radius": "12px",
    "border": "1px solid var(--color-border-hairline)",
    "background": "var(--color-surface-card)",
    "display": "flex",
    "align-items": "center",
    "gap": "10px",
    "#": ["$NameEl", "$Spacer", "$RenameBtn", "$DeleteBtn"],

    "$NameEl": {
        "#element": "div",
        "@id": "edit-profile-row-/I/-name",
        "font-size": "15px",
        "font-weight": "500",
        "color": "var(--color-text-primary)",
        "min-width": "0",
        "overflow": "hidden",
        "text-overflow": "ellipsis",
        "white-space": "nowrap"
    },

    "$Spacer": {
        "#element": "div",
        "flex": "1"
    },

    "$RenameBtn": {
        "#element": "button",
        "@id": "edit-profile-row-/I/-rename",
        "padding": "6px 10px",
        "border-radius": "8px",
        "background": "transparent",
        "border": "1px solid var(--color-border-hairline)",
        "cursor": "pointer",
        "font-family": "inherit",
        "font-size": "12px",
        "font-weight": "500",
        "color": "var(--color-text-primary)",
        "flex-shrink": "0",
        "#content": "Rename"
    },

    "$DeleteBtn": {
        "#element": "button",
        "@id": "edit-profile-row-/I/-delete",
        "padding": "6px 10px",
        "border-radius": "8px",
        "background": "transparent",
        "border": "1px solid var(--color-border-hairline)",
        "cursor": "pointer",
        "font-family": "inherit",
        "font-size": "12px",
        "font-weight": "500",
        "color": "var(--color-text-primary)",
        "flex-shrink": "0",
        "#content": "Delete"
    }
}
