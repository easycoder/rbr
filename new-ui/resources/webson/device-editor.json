{
    "#doc": "Device editor sheet — per-room thermometer + relay configuration. Room picker at top (selects which room to edit), then sensor name, relay type pill, linked toggle, relay names list. Save ships an Update Profiles uirequest with the full profiles array (device fields fanned out to all profiles).",
    "#element": "div",
    "@id": "device-editor-sheet",
    "#": ["$Tagline", "$RoomPill", "$RoomPicker", "$SensorBlock", "$RelayTypeBlock", "$LinkedBlock", "$RelaysBlock", "$RequestRelayBlock", "$Buttons"],

    "$Tagline": {
        "#element": "div",
        "margin-top": "2px",
        "font-size": "13px",
        "font-weight": "400",
        "color": "var(--color-text-secondary)",
        "#content": "Configure the thermometer and relays for the selected room. Save to apply, Cancel to discard."
    },

    "$RoomPill": {
        "#element": "button",
        "@id": "device-editor-room-pill",
        "width": "100%",
        "margin-top": "12px",
        "padding": "10px 14px",
        "border-radius": "12px",
        "background": "transparent",
        "border": "1px solid var(--color-border-hairline)",
        "cursor": "pointer",
        "font-family": "inherit",
        "display": "flex",
        "align-items": "center",
        "gap": "10px",
        "#": ["$RoomLabel", "$RoomValue", "$RoomSpacer", "$RoomChev"],

        "$RoomLabel": {
            "#element": "div",
            "font-size": "var(--type-section-label-size)",
            "font-weight": "var(--type-section-label-weight)",
            "letter-spacing": "var(--type-section-label-track)",
            "text-transform": "uppercase",
            "color": "var(--color-text-meta)",
            "#content": "Room"
        },
        "$RoomValue": {
            "#element": "div",
            "@id": "device-editor-room-value",
            "font-size": "14px",
            "font-weight": "500",
            "color": "var(--color-text-primary)"
        },
        "$RoomSpacer": { "#element": "div", "flex": "1" },
        "$RoomChev": {
            "#element": "div",
            "@id": "device-editor-room-chev",
            "width": "12px",
            "height": "12px",
            "background-color": "var(--color-text-disabled)",
            "mask": "url(resources/icon/chevron.svg) center/contain no-repeat",
            "-webkit-mask": "url(resources/icon/chevron.svg) center/contain no-repeat",
            "flex-shrink": "0"
        }
    },

    "$RoomPicker": {
        "#element": "div",
        "@id": "device-editor-room-picker",
        "margin-top": "8px",
        "padding": "10px 12px",
        "border-radius": "10px",
        "background": "var(--color-surface-card)",
        "border": "1px solid var(--color-border-hairline)",
        "display": "none",
        "flex-wrap": "wrap",
        "gap": "6px"
    },

    "$SensorBlock": {
        "#element": "div",
        "margin-top": "14px",
        "#": ["$SensorLabel", "$SensorInput"],

        "$SensorLabel": {
            "#element": "div",
            "margin-bottom": "6px",
            "font-size": "var(--type-section-label-size)",
            "font-weight": "var(--type-section-label-weight)",
            "letter-spacing": "var(--type-section-label-track)",
            "color": "var(--color-text-meta)",
            "text-transform": "uppercase",
            "#content": "Thermometer (name or address)"
        },

        "$SensorInput": {
            "#element": "input",
            "@id": "device-editor-sensor",
            "@type": "text",
            "@spellcheck": "false",
            "@autocapitalize": "none",
            "@autocomplete": "off",
            "width": "100%",
            "padding": "10px 12px",
            "border": "1px solid var(--color-border-hairline)",
            "border-radius": "10px",
            "background": "var(--color-surface-card)",
            "font-family": "inherit",
            "font-size": "14px",
            "color": "var(--color-text-primary)",
            "box-sizing": "border-box"
        }
    },

    "$RelayTypeBlock": {
        "#element": "div",
        "margin-top": "14px",
        "#": ["$RelayTypeLabel", "$RelayTypePill"],

        "$RelayTypeLabel": {
            "#element": "div",
            "margin-bottom": "6px",
            "font-size": "var(--type-section-label-size)",
            "font-weight": "var(--type-section-label-weight)",
            "letter-spacing": "var(--type-section-label-track)",
            "color": "var(--color-text-meta)",
            "text-transform": "uppercase",
            "#content": "Relay type"
        },

        "$RelayTypePill": {
            "#element": "div",
            "background": "var(--color-surface-sunk)",
            "padding": "4px",
            "border-radius": "12px",
            "display": "grid",
            "grid-template-columns": "1fr 1fr",
            "gap": "6px",
            "#": ["$BtnRBRNow", "$BtnZigbee"],

            "$BtnRBRNow": { "$ID": "device-editor-rt-rbrnow", "$Label": "RBR-Now", "#": "$RTBtn" },
            "$BtnZigbee": { "$ID": "device-editor-rt-zigbee", "$Label": "Zigbee",  "#": "$RTBtn" },

            "$RTBtn": {
                "#element": "button",
                "@id": "$ID",
                "padding": "10px 6px",
                "border": "0",
                "border-radius": "9px",
                "background": "transparent",
                "color": "var(--color-text-muted)",
                "font-family": "inherit",
                "font-size": "13px",
                "font-weight": "500",
                "cursor": "pointer",
                "#content": "$Label"
            }
        }
    },

    "$LinkedBlock": {
        "#element": "div",
        "margin-top": "14px",
        "#": ["$LinkedLabel", "$LinkedRow"],

        "$LinkedLabel": {
            "#element": "div",
            "margin-bottom": "6px",
            "font-size": "var(--type-section-label-size)",
            "font-weight": "var(--type-section-label-weight)",
            "letter-spacing": "var(--type-section-label-track)",
            "color": "var(--color-text-meta)",
            "text-transform": "uppercase",
            "#content": "Sensor controls relay"
        },
        "$LinkedRow": {
            "#element": "div",
            "display": "flex",
            "gap": "12px",
            "align-items": "center",
            "padding": "10px 14px",
            "background": "var(--color-surface-card)",
            "border": "1px solid var(--color-border-hairline)",
            "border-radius": "12px",
            "#": ["$LinkedText", "$Spacer", "$LinkedBtn"],

            "$LinkedText": {
                "#element": "div",
                "font-size": "13px",
                "color": "var(--color-text-secondary)",
                "#content": "Link sensor and relay so the room thermostats itself"
            },
            "$Spacer": {
                "#element": "div",
                "flex": "1"
            },
            "$LinkedBtn": {
                "#element": "button",
                "@id": "device-editor-linked-btn",
                "padding": "8px 18px",
                "border": "1px solid var(--color-border-hairline)",
                "border-radius": "10px",
                "background": "var(--color-surface-card)",
                "color": "var(--color-text-primary)",
                "font-family": "inherit",
                "font-size": "13px",
                "font-weight": "500",
                "cursor": "pointer",
                "min-width": "60px",
                "#content": "Off"
            }
        }
    },

    "$RelaysBlock": {
        "#element": "div",
        "margin-top": "14px",
        "#": ["$RelaysLabel", "$RelaysInput"],

        "$RelaysLabel": {
            "#element": "div",
            "margin-bottom": "6px",
            "font-size": "var(--type-section-label-size)",
            "font-weight": "var(--type-section-label-weight)",
            "letter-spacing": "var(--type-section-label-track)",
            "color": "var(--color-text-meta)",
            "text-transform": "uppercase",
            "#content": "Relays (one per line)"
        },

        "$RelaysInput": {
            "#element": "textarea",
            "@id": "device-editor-relays",
            "@spellcheck": "false",
            "@autocapitalize": "none",
            "@autocomplete": "off",
            "width": "100%",
            "min-height": "80px",
            "padding": "10px 12px",
            "border": "1px solid var(--color-border-hairline)",
            "border-radius": "10px",
            "background": "var(--color-surface-card)",
            "font-family": "inherit",
            "font-size": "14px",
            "color": "var(--color-text-primary)",
            "box-sizing": "border-box",
            "resize": "vertical"
        }
    },

    "$RequestRelayBlock": {
        "#doc": "System-wide setting (not per-room): the Zigbee relay that drives the boiler whenever any room is calling for heat. Blank = the system has no demand relay.",
        "#element": "div",
        "margin-top": "20px",
        "padding-top": "16px",
        "border-top": "1px solid var(--color-border-divider-soft)",
        "#": ["$RequestLabel", "$RequestInput", "$RequestHint"],

        "$RequestLabel": {
            "#element": "div",
            "margin-bottom": "6px",
            "font-size": "var(--type-section-label-size)",
            "font-weight": "var(--type-section-label-weight)",
            "letter-spacing": "var(--type-section-label-track)",
            "color": "var(--color-text-meta)",
            "text-transform": "uppercase",
            "#content": "Demand relay (Zigbee)"
        },

        "$RequestInput": {
            "#element": "input",
            "@id": "device-editor-request",
            "@type": "text",
            "@spellcheck": "false",
            "@autocapitalize": "none",
            "@autocomplete": "off",
            "@placeholder": "(none)",
            "width": "100%",
            "padding": "10px 12px",
            "border": "1px solid var(--color-border-hairline)",
            "border-radius": "10px",
            "background": "var(--color-surface-card)",
            "font-family": "inherit",
            "font-size": "14px",
            "color": "var(--color-text-primary)",
            "box-sizing": "border-box"
        },

        "$RequestHint": {
            "#element": "div",
            "margin-top": "6px",
            "font-size": "11px",
            "color": "var(--color-text-muted)",
            "#content": "Leave blank if your boiler doesn't need an external demand relay."
        }
    },

    "$Buttons": {
        "#element": "div",
        "margin-top": "20px",
        "display": "flex",
        "gap": "10px",
        "#": ["$CancelBtn", "$SaveBtn"],

        "$CancelBtn": {
            "#element": "button",
            "@id": "device-editor-cancel-btn",
            "flex": "1",
            "padding": "12px",
            "border-radius": "12px",
            "background": "var(--color-surface-card)",
            "border": "1px solid var(--color-border-hairline)",
            "cursor": "pointer",
            "font-family": "inherit",
            "font-size": "14px",
            "font-weight": "500",
            "color": "var(--color-text-primary)",
            "#content": "Cancel"
        },

        "$SaveBtn": {
            "#element": "button",
            "@id": "device-editor-save-btn",
            "flex": "1",
            "padding": "12px",
            "border-radius": "12px",
            "background": "var(--color-accent)",
            "border": "1px solid var(--color-accent)",
            "cursor": "pointer",
            "font-family": "inherit",
            "font-size": "14px",
            "font-weight": "600",
            "color": "white",
            "#content": "Save devices"
        }
    }
}
