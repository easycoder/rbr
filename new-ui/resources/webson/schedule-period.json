{
    "#doc": "Schedule period card — one event in the room's events[] array. /I/ replaced with the period index. Vertical stack: time stepper row, target stepper row; ✕ delete button in the top-right corner.",
    "#element": "div",
    "@id": "schedule-period-/I/",
    "padding": "14px 14px 12px 14px",
    "border-radius": "12px",
    "border": "1px solid var(--color-border-hairline)",
    "background": "var(--color-surface-card)",
    "position": "relative",
    "display": "flex",
    "flex-direction": "column",
    "gap": "10px",
    "#": ["$TimeRow", "$TempRow", "$DeleteBtn"],

    "$TimeRow": {
        "#element": "div",
        "display": "flex",
        "align-items": "center",
        "gap": "10px",
        "#": ["$TimeLabel", "$TimeSpacer", "$TimeMinus", "$TimeValue", "$TimePlus"],

        "$TimeLabel": {
            "#element": "div",
            "font-size": "12px",
            "font-weight": "500",
            "letter-spacing": "0.3px",
            "text-transform": "uppercase",
            "color": "var(--color-text-meta)",
            "#content": "Starts at"
        },
        "$TimeSpacer": { "#element": "div", "flex": "1" },
        "$TimeMinus": {
            "#element": "button",
            "@id": "schedule-period-/I/-time-minus",
            "width": "30px",
            "height": "30px",
            "padding": "0",
            "border-radius": "8px",
            "background": "transparent",
            "border": "1px solid var(--color-border-hairline)",
            "cursor": "pointer",
            "font-family": "inherit",
            "font-size": "16px",
            "font-weight": "600",
            "color": "var(--color-text-primary)",
            "display": "flex",
            "align-items": "center",
            "justify-content": "center",
            "flex-shrink": "0",
            "#content": "−"
        },
        "$TimeValue": {
            "#element": "div",
            "@id": "schedule-period-/I/-time-value",
            "min-width": "60px",
            "text-align": "center",
            "font-size": "16px",
            "font-weight": "600",
            "font-variant-numeric": "tabular-nums",
            "color": "var(--color-text-primary)"
        },
        "$TimePlus": {
            "#element": "button",
            "@id": "schedule-period-/I/-time-plus",
            "width": "30px",
            "height": "30px",
            "padding": "0",
            "border-radius": "8px",
            "background": "transparent",
            "border": "1px solid var(--color-border-hairline)",
            "cursor": "pointer",
            "font-family": "inherit",
            "font-size": "16px",
            "font-weight": "600",
            "color": "var(--color-text-primary)",
            "display": "flex",
            "align-items": "center",
            "justify-content": "center",
            "flex-shrink": "0",
            "#content": "+"
        }
    },

    "$TempRow": {
        "#element": "div",
        "display": "flex",
        "align-items": "center",
        "gap": "10px",
        "#": ["$TempLabel", "$TempSpacer", "$TempMinus", "$TempValue", "$TempPlus"],

        "$TempLabel": {
            "#element": "div",
            "font-size": "12px",
            "font-weight": "500",
            "letter-spacing": "0.3px",
            "text-transform": "uppercase",
            "color": "var(--color-text-meta)",
            "#content": "Target"
        },
        "$TempSpacer": { "#element": "div", "flex": "1" },
        "$TempMinus": {
            "#element": "button",
            "@id": "schedule-period-/I/-temp-minus",
            "width": "30px",
            "height": "30px",
            "padding": "0",
            "border-radius": "8px",
            "background": "transparent",
            "border": "1px solid var(--color-border-hairline)",
            "cursor": "pointer",
            "font-family": "inherit",
            "font-size": "16px",
            "font-weight": "600",
            "color": "var(--color-text-primary)",
            "display": "flex",
            "align-items": "center",
            "justify-content": "center",
            "flex-shrink": "0",
            "#content": "−"
        },
        "$TempValue": {
            "#element": "div",
            "@id": "schedule-period-/I/-temp-value",
            "min-width": "60px",
            "text-align": "center",
            "font-size": "16px",
            "font-weight": "600",
            "font-variant-numeric": "tabular-nums",
            "color": "var(--color-text-primary)"
        },
        "$TempPlus": {
            "#element": "button",
            "@id": "schedule-period-/I/-temp-plus",
            "width": "30px",
            "height": "30px",
            "padding": "0",
            "border-radius": "8px",
            "background": "transparent",
            "border": "1px solid var(--color-border-hairline)",
            "cursor": "pointer",
            "font-family": "inherit",
            "font-size": "16px",
            "font-weight": "600",
            "color": "var(--color-text-primary)",
            "display": "flex",
            "align-items": "center",
            "justify-content": "center",
            "flex-shrink": "0",
            "#content": "+"
        }
    },

    "$DeleteBtn": {
        "#element": "button",
        "@id": "schedule-period-/I/-delete",
        "align-self": "flex-end",
        "margin-top": "-2px",
        "padding": "4px 10px",
        "border-radius": "6px",
        "background": "transparent",
        "border": "1px solid var(--color-border-hairline)",
        "cursor": "pointer",
        "font-family": "inherit",
        "font-size": "12px",
        "color": "#C8392E",
        "#content": "Delete period"
    }
}
