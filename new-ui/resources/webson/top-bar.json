{
    "#doc": "Room By Room — TopBar. Slice 02.",
    "@id": "top-bar",
    "display": "flex",
    "align-items": "center",
    "gap": "12px",
    "padding": "10px 18px 8px 18px",
    "background": "rgba(255,255,255,0.82)",
    "backdrop-filter": "blur(16px)",
    "-webkit-backdrop-filter": "blur(16px)",
    "border-bottom": "1px solid rgba(0,0,0,0.05)",
    "position": "sticky",
    "top": "0",
    "z-index": "10",
    "#": ["$Mark", "$Text", "$Spacer", "$MenuBtn"],

    "$Mark": {
        "#element": "div",
        "width": "34px",
        "height": "34px",
        "border-radius": "10px",
        "background": "var(--color-accent)",
        "box-shadow": "var(--shadow-house-mark)",
        "display": "flex",
        "align-items": "center",
        "justify-content": "center",
        "flex-shrink": "0",
        "#": "$Glyph",

        "$Glyph": {
            "#element": "img",
            "@src": "resources/icon/house.svg",
            "@alt": "",
            "width": "20px",
            "height": "20px",
            "pointer-events": "none"
        }
    },

    "$Text": {
        "#element": "div",
        "display": "flex",
        "flex-direction": "column",
        "line-height": "1.15",
        "#": ["$AppName", "$SystemId"],

        "$AppName": {
            "#element": "div",
            "@id": "top-bar-app-name",
            "font-size": "var(--type-app-name-size)",
            "font-weight": "var(--type-app-name-weight)",
            "letter-spacing": "var(--type-app-name-track)",
            "color": "var(--color-text-primary)",
            "#content": "Room By Room"
        },

        "$SystemId": {
            "#element": "div",
            "@id": "top-bar-system-id",
            "font-size": "11px",
            "font-weight": "400",
            "color": "var(--color-text-muted)",
            "margin-top": "-1px"
        }
    },

    "$Spacer": {
        "#element": "div",
        "flex": "1"
    },

    "$MenuBtn": {
        "#element": "button",
        "@id": "top-bar-menu-btn",
        "@aria-label": "Menu",
        "width": "38px",
        "height": "38px",
        "border-radius": "12px",
        "border": "0",
        "background": "rgba(0,0,0,0.04)",
        "display": "flex",
        "align-items": "center",
        "justify-content": "center",
        "cursor": "pointer",
        "flex-shrink": "0",
        "position": "relative",
        "#": ["$HitArea", "$Glyph"],

        "$HitArea": {
            "#doc": "Invisible 44x44 expansion for touch — handoff requires ≥44px hit area.",
            "#element": "div",
            "position": "absolute",
            "top": "-3px",
            "left": "-3px",
            "right": "-3px",
            "bottom": "-3px",
            "pointer-events": "none"
        },

        "$Glyph": {
            "#element": "img",
            "@src": "resources/icon/hamburger.png",
            "@alt": "",
            "width": "18px",
            "height": "18px",
            "pointer-events": "none",
            "opacity": "0.72"
        }
    }
}
