{
    "#doc": "Profile editor — list of profiles each with rename/delete, add (duplicate current) button, edit-calendar entry, save/cancel buttons. Renders as a sibling sheet inside sheet-content.",
    "#element": "div",
    "@id": "edit-profiles-sheet",
    "#": ["$Tagline", "$List", "$AddBtn", "$CalBtn", "$Buttons"],

    "$Tagline": {
        "#element": "div",
        "margin-top": "2px",
        "font-size": "13px",
        "font-weight": "400",
        "color": "var(--color-text-secondary)",
        "#content": "Rename, delete or duplicate profiles. Save to apply, Cancel to discard."
    },

    "$List": {
        "#element": "div",
        "@id": "edit-profile-list",
        "margin-top": "16px",
        "display": "flex",
        "flex-direction": "column",
        "gap": "8px"
    },

    "$AddBtn": {
        "#element": "button",
        "@id": "edit-profiles-add-btn",
        "width": "100%",
        "margin-top": "12px",
        "padding": "12px",
        "border-radius": "12px",
        "background": "transparent",
        "border": "1px dashed var(--color-border-hairline)",
        "cursor": "pointer",
        "font-family": "inherit",
        "font-size": "14px",
        "font-weight": "500",
        "color": "var(--color-text-primary)",
        "#content": "+ Add profile (duplicate current)"
    },

    "$CalBtn": {
        "#element": "button",
        "@id": "edit-profiles-cal-btn",
        "width": "100%",
        "margin-top": "12px",
        "padding": "12px",
        "border-radius": "12px",
        "background": "transparent",
        "border": "1px solid var(--color-border-hairline)",
        "cursor": "pointer",
        "font-family": "inherit",
        "font-size": "14px",
        "font-weight": "400",
        "color": "var(--color-text-primary)",
        "#content": "Edit calendar…"
    },

    "$Buttons": {
        "#element": "div",
        "margin-top": "20px",
        "display": "flex",
        "gap": "10px",
        "#": ["$CancelBtn", "$SaveBtn"],

        "$CancelBtn": {
            "#element": "button",
            "@id": "edit-profiles-cancel-btn",
            "flex": "1",
            "padding": "12px",
            "border-radius": "12px",
            "background": "var(--color-surface-card)",
            "border": "1px solid var(--color-border-hairline)",
            "cursor": "pointer",
            "font-family": "inherit",
            "font-size": "14px",
            "font-weight": "500",
            "color": "var(--color-text-primary)",
            "#content": "Cancel"
        },

        "$SaveBtn": {
            "#element": "button",
            "@id": "edit-profiles-save-btn",
            "flex": "1",
            "padding": "12px",
            "border-radius": "12px",
            "background": "var(--color-accent)",
            "border": "1px solid var(--color-accent)",
            "cursor": "pointer",
            "font-family": "inherit",
            "font-size": "14px",
            "font-weight": "600",
            "color": "white",
            "#content": "Save changes"
        }
    }
}
