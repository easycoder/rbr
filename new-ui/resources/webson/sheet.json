{
    "#doc": "Reusable bottom-sheet chrome: scrim + container + header + empty content slot. shell.as toggles pointer-events + opacity + transform to open/close; CSS transitions do the animation.",
    "#element": "div",
    "@id": "sheet-root",
    "position": "fixed",
    "inset": "0",
    "z-index": "100",
    "pointer-events": "none",
    "#": ["$Scrim", "$Container"],

    "$Scrim": {
        "#element": "div",
        "@id": "sheet-scrim",
        "position": "absolute",
        "inset": "0",
        "background": "var(--color-scrim)",
        "opacity": "0",
        "transition": "opacity var(--motion-scrim-fade)"
    },

    "$Container": {
        "#element": "div",
        "@id": "sheet-container",
        "position": "absolute",
        "bottom": "0",
        "left": "0",
        "right": "0",
        "max-width": "420px",
        "margin": "0 auto",
        "background": "var(--color-surface-card)",
        "border-radius": "var(--radius-sheet) var(--radius-sheet) 0 0",
        "max-height": "85vh",
        "overflow-y": "auto",
        "transform": "translateY(100%)",
        "transition": "transform var(--motion-sheet-slide)",
        "box-shadow": "var(--shadow-sheet)",
        "#": ["$Grabber", "$Header", "$Content"],

        "$Grabber": {
            "#element": "div",
            "width": "40px",
            "height": "4px",
            "background": "#E5E5E7",
            "border-radius": "2px",
            "margin": "10px auto 0 auto"
        },

        "$Header": {
            "#element": "div",
            "display": "flex",
            "align-items": "center",
            "gap": "8px",
            "padding": "8px 20px 4px 20px",
            "#": ["$Title", "$Spacer", "$Close"],

            "$Title": {
                "#element": "div",
                "@id": "sheet-title",
                "font-size": "var(--type-sheet-title-size)",
                "font-weight": "var(--type-sheet-title-weight)",
                "letter-spacing": "var(--type-sheet-title-track)",
                "color": "var(--color-text-primary)",
                "#content": " "
            },

            "$Spacer": {
                "#element": "div",
                "flex": "1"
            },

            "$Close": {
                "#element": "button",
                "@id": "sheet-close-btn",
                "width": "30px",
                "height": "30px",
                "border-radius": "50%",
                "background": "var(--color-chip-neutral-bg)",
                "border": "0",
                "display": "flex",
                "align-items": "center",
                "justify-content": "center",
                "cursor": "pointer",
                "flex-shrink": "0",
                "padding": "0",
                "#": "$X",

                "$X": {
                    "#element": "div",
                    "width": "14px",
                    "height": "14px",
                    "background-color": "var(--color-text-secondary)",
                    "mask": "url(resources/icon/close.svg) center/contain no-repeat",
                    "-webkit-mask": "url(resources/icon/close.svg) center/contain no-repeat",
                    "pointer-events": "none"
                }
            }
        },

        "$Content": {
            "#element": "div",
            "@id": "sheet-content",
            "padding": "4px 20px 24px 20px"
        }
    }
}
