[Unit]
Description=RBR Statistics Listener
After=mosquitto.service
Wants=mosquitto.service

[Service]
Type=simple
EnvironmentFile=/opt/rbr/stats-listener.env
ExecStart=/usr/bin/python3 -u /opt/rbr/stats-listener.py --username ${MQTT_USER} --password ${MQTT_PASS}
Restart=on-failure
RestartSec=10

[Install]
WantedBy=multi-user.target
